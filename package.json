  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-static-copy": "^3.0.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.0.0",
    "workbox-core": "^7.3.0",
    "workbox-expiration": "^7.3.0",
