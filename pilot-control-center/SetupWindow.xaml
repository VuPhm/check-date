<Window x:Class="CoopFoodPilot.ControlCenter.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cấu hình cụm pilot" Height="630" Width="650" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <Grid Margin="26">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="18" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <StackPanel><TextBlock Text="Cấu hình cụm" FontSize="24" FontWeight="SemiBold" /><TextBlock Text="Thông tin này chỉ lưu cục bộ trên máy trưởng cụm." Foreground="#666" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="2"><TextBlock Text="Dữ liệu SQLite" /><TextBox x:Name="DatabaseFile" Text="D:\CoopFoodPilot\data\pilot.sqlite" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="4"><TextBlock Text="Thư mục backup" /><TextBox x:Name="BackupDirectory" Text="E:\CoopFoodPilot\backups" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="6"><TextBlock Text="Link công khai" /><TextBox x:Name="PublicUrl" Text="https://c01.tenmiencuaban.vn" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="8"><TextBlock Text="Cloudflare Tunnel token" /><PasswordBox x:Name="TunnelToken" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="10"><TextBlock Text="Mã cửa hàng đầu tiên" /><TextBox x:Name="BootstrapStoreCode" Text="0001" MaxLength="4" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="12"><TextBlock Text="Mật khẩu CHT đầu tiên (ít nhất 12 ký tự)" /><PasswordBox x:Name="BootstrapManagerPassword" Margin="0,5,0,0" /></StackPanel>
    <StackPanel Grid.Row="14"><TextBlock Text="PIN tham gia đầu tiên (4 số)" /><PasswordBox x:Name="BootstrapJoinCode" MaxLength="4" Margin="0,5,0,0" /></StackPanel>
    <DockPanel Grid.Row="16"><TextBlock x:Name="ValidationText" Foreground="#B42318" VerticalAlignment="Center" /><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Hủy" IsCancel="True" Padding="16,8" Margin="0,0,8,0" /><Button Content="Lưu cấu hình" Click="Save_Click" IsDefault="True" Padding="16,8" /></StackPanel></DockPanel>
  </Grid>
</Window>
